<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_icon"
            android:layout_width="42dp"
            android:layout_height="42dp"
            app:cardBackgroundColor="#F0F0F0"
            app:cardCornerRadius="8dp"
            app:contentPadding="5dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_category_icon"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                tools:src="@drawable/ic_category_breakfast" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tv_category_group_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:textColor="#333333"
            android:textSize="15sp"
            app:layout_constraintBottom_toBottomOf="@id/card_icon"
            app:layout_constraintStart_toEndOf="@id/card_icon"
            app:layout_constraintTop_toTopOf="@id/card_icon"
            tools:text="Dịch vụ sinh hoạt" />

        <TextView
            android:id="@+id/tv_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#333333"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/card_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/card_icon"
            tools:text="8.000.000 đ" />

        <TextView
            android:id="@+id/tv_percent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="6dp"
            android:textColor="#808080"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tv_amount"
            app:layout_constraintEnd_toStartOf="@id/tv_amount"
            app:layout_constraintTop_toTopOf="@id/tv_amount"
            tools:text="(41,7%)" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:max="1000"
        app:indicatorColor="#FF9800"
        app:trackColor="#F0F0F0"
        app:trackThickness="8dp"
        app:trackCornerRadius="4dp"
        tools:progress="417" />

    <View
        android:id="@+id/view_divider"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:background="#F0F0F0" />

</LinearLayout>