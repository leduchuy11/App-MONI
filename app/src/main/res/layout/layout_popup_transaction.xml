<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="12dp"
    app:cardElevation="8dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingVertical="8dp">

        <LinearLayout
            android:id="@+id/row_expense"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_flying_money"
                 />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Chi tiền"
                android:textColor="#333333"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/ic_check_expense"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tick"
                android:visibility="visible"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_income"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_collect_money" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Thu tiền"
                android:textColor="#333333"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/ic_check_income"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tick"
                android:visibility="invisible" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_transfer"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_transfer" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Chuyển khoản"
                android:textColor="#333333"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/ic_check_transfer"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tick"
                android:visibility="invisible"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_lend"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_loan" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Cho vay"
                android:textColor="#333333"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/ic_check_lend"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tick"
                android:visibility="invisible"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/row_borrow"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_borrow" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:text="Đi vay"
                android:textColor="#333333"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/ic_check_borrow"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_tick"
                android:visibility="invisible" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>