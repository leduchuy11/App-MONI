<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AppMoni" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
        <!--        <item name="android:statusBarColor">@color/white</item>-->
        <item name="android:windowSplashScreenBackground">#FFFFFF</item>

        <item name="android:windowBackground">#FFFFFF</item>
    </style>

    <style name="Theme.AppMoni" parent="Base.Theme.AppMoni">
        <item name="android:statusBarColor">@color/blue_bottomnav</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/blue_bottomnav</item>

    </style>

    //Themes của riêng activitty login

    <style name="Theme.AppMoni.Login" parent="Base.Theme.AppMoni">
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">#FFFFFF</item>

        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="BottomNavTextStyle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
    </style>

    <style name="SolidWhiteIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">#FFFFFF</item>
        <item name="android:width">56dp</item>
        <item name="android:height">32dp</item>
    </style>

    <!--    Avatar ở home - header-->
    <style name="ShapeAppearanceOverlay.AppMoni.Circular" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>


    <style name="CategoryItemStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">12dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
    </style>

    <style name="CategoryIconStyle">
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:padding">1dp</item>
    </style>

    <style name="CategoryTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">4dp</item>
        <item name="android:textColor">#424242</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="AddTransDividerStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#F0F0F0</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
    </style>


    <!-- Style cho 1 hàng trong Card Chi tiết -->
    <style name="DetailRowStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Style cho Tiêu đề bên trái (Màu xám) -->
    <style name="DetailLabelStyle">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">#757575</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Style cho Giá trị bên phải (Màu đen, căn phải) -->
    <style name="DetailValueStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:gravity">end</item>
        <item name="android:textColor">#333333</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- Style cho Đường kẻ ngang -->
    <style name="DetailDividerStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:background">#EEEEEE</item>
    </style>

    <style name="ShapeAppearanceOverlay.App.CornerSize4dp" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4dp</item>
    </style>


</resources>