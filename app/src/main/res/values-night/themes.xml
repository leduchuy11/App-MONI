<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.AppMoni" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <!-- <item name="colorPrimary">@color/my_dark_primary</item> -->
        <item name="android:windowSplashScreenBackground">#FFFFFF</item>

        <item name="android:windowBackground">#FFFFFF</item>
    </style>

    <style name="Theme.AppMoni" parent="Base.Theme.AppMoni" >
        <item name="android:statusBarColor">@color/blue_bottomnav</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/blue_bottomnav</item>

    </style>

    //Themes của riêng activitty login
    <style name="Theme.AppMoni.Login" parent="Base.Theme.AppMoni">
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">#FFFFFF</item>

        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    Avatar ở home -header
    <style name="ShapeAppearanceOverlay.AppMoni.Circular" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>


</resources>